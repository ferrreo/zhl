grammar "source.php" {
    name "PHP";
    scope root = "source.php";

    context main {
        line_comment "//" scope "comment.line.double-slash.php";
        line_comment "#" scope "comment.line.number-sign.php";
        block_comment "/*" "*/" scope "comment.block.php";
        string "\"" escape "\\" scope "string.quoted.double.php";
        string "'" escape "\\" scope "string.quoted.single.php";
        number generic scope "constant.numeric.php";
        regex "\\$[A-Za-z_][A-Za-z0-9_]*" scope "variable.other.php";
        keywords "__halt_compiler abstract and array as break callable case catch class clone const continue declare default do echo else elseif empty enddeclare endfor endforeach endif endswitch endwhile enum eval exit extends final finally fn for foreach function global goto if implements include include_once instanceof insteadof interface isset list match namespace new or print private protected public readonly require require_once return static switch throw trait try unset use var while xor yield from" scope "keyword.control.php";
        keywords "bool boolean false float int integer mixed never null object parent self string true void" scope "storage.type.php";
        function_call scope "entity.name.function.php";
        capitalized_identifier scope "entity.name.type.php";
        operators "-> ?-> :: ++ -- <= >= == != === !== && || += -= *= /= %= .= ?? => ..." scope "keyword.operator.php";
        operators "+ - * / % = < > & | ^ ~ ! ? : ; , . { } ( ) [ ]" scope "keyword.operator.php";
    }
}
